generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestionKind {
  /** Pre-seeded Wikipedia-RAG bank (`qb_*`). */
  BANK
  /** Free-form user question (hash slug `q_*`). */
  DYNAMIC
  /** References manual flows q2–q4 (no Wikipedia corpus). */
  MANUAL_REF
}

enum AnswerSource {
  MANUAL_Q2
  MANUAL_Q3
  MANUAL_Q4
  WEB_RAG
  BANK_RAG
}

model Question {
  id         String       @id @default(cuid())
  slug       String       @unique
  title      String
  promptText String?      @db.Text
  kind       QuestionKind @default(DYNAMIC)
  createdAt  DateTime     @default(now())
  chunks     RagChunk[]
  answers    Answer[]
}

/// Vector-indexed Wikipedia (or fallback) chunks for RAG. DB table legacy name `CorpusEntry`.
model RagChunk {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  meta       Json?
  embedding  Json?
  createdAt  DateTime @default(now())

  @@index([questionId])
  @@map("CorpusEntry")
}

/// Stored responses from manual flows or RAG retrieval (audit / demo).
model Answer {
  id         String        @id @default(cuid())
  questionId String?
  question   Question?     @relation(fields: [questionId], references: [id], onDelete: SetNull)
  source     AnswerSource
  payload    Json
  createdAt  DateTime      @default(now())

  @@index([questionId])
  @@index([source])
}

/// One row per training/indexing batch (e.g. 100-question bank job).
model RagTrainingRun {
  id         String    @id @default(cuid())
  label      String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  metrics    Json?

  @@index([startedAt])
}

/// Wikipedia-fetched summary + metadata per disease slug (aligns with `src/diseases/registry.ts`).
model DiseaseWebInfo {
  id               String   @id @default(cuid())
  slug             String   @unique
  displayName      String
  wikipediaTitle   String?
  summary          String   @db.Text
  sourceUrl        String?
  sectionsJson     Json?
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Specialist / referral-style bullets derived from Wikipedia sections (educational only).
model DiseaseSpecialistInfo {
  id               String  @id @default(cuid())
  diseaseSlug      String
  specialistType   String
  roleDescription  String  @db.Text
  whenToSee        String? @db.Text
  sourceExcerpt    String? @db.Text
  sourceSection    String?
  createdAt        DateTime @default(now())

  @@index([diseaseSlug])
}

/// Yoga / pranayama / breathwork notes (section-derived or conservative templates).
model DiseaseYogaPranayamInfo {
  id            String   @id @default(cuid())
  diseaseSlug   String
  practiceName  String
  description   String   @db.Text
  cautionNote   String?  @db.Text
  sourceExcerpt String?  @db.Text
  sourceSection String?
  createdAt     DateTime @default(now())

  @@index([diseaseSlug])
}

/// Demo criticality score (0–100) from heuristics — not a validated clinical metric.
model DiseaseCriticalityProfile {
  id                   String   @id @default(cuid())
  diseaseSlug          String   @unique
  criticalityPercent   Float
  rationale            String   @db.Text
  method               String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Ingested PDF/image (or placeholder) for per-disease corpus ML. Not for clinical use.
enum DiseaseTrainingAssetKind {
  PDF
  IMAGE
}

model DiseaseTrainingAsset {
  id              String                 @id @default(cuid())
  diseaseSlug     String
  functionality   String                 @default("educational_triage_text")
  kind            DiseaseTrainingAssetKind
  mimeType        String
  sha256          String
  storageKey      String
  extractedText   String?                @db.Text
  /// Optional 0/1 for supervised training; if null, pseudo-labels are derived (demo only).
  trainingLabel   Int?
  meta            Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([diseaseSlug, functionality, sha256])
  @@index([diseaseSlug, functionality])
}

/// Which sklearn pipeline ("formula") applies for a disease + functionality (data-driven).
model DiseaseFunctionalityConfig {
  id              String                @id @default(cuid())
  diseaseSlug     String
  functionality   String
  formulaKey      String
  hyperparams     Json?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  trainedModels   DiseaseTrainedModel[]

  @@unique([diseaseSlug, functionality])
  @@index([diseaseSlug])
}

/// Versioned trained artifact pointer + metrics (artifact bytes in object storage or local path).
model DiseaseTrainedModel {
  id                 String                   @id @default(cuid())
  configId           String
  config             DiseaseFunctionalityConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  version            Int                      @default(1)
  artifactStorageKey String
  metrics            Json?
  trainedAt          DateTime                 @default(now())
  nSamples           Int

  @@index([configId, trainedAt])
}

/// Dev-only: remembered fixes for self-healing orchestrator (`npm run healer`).
enum HealerTechStack {
  NODE_TS
  NEXT
  PYTHON
}

enum HealerFixSource {
  LLM
  MANUAL
  CACHE
}

/// Normalized error fingerprint → structured search/replace edits (JSON).
model ErrorFixPattern {
  id                 String          @id @default(cuid())
  techStack          HealerTechStack
  patternHash        String
  primaryFilePath    String?
  normalizedSnippet  String          @db.Text
  rawSnippetPreview  String?         @db.Text
  fixPayload         Json
  createdFrom        HealerFixSource @default(LLM)
  successCount       Int             @default(0)
  missCount          Int             @default(0)
  lastAppliedAt      DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([techStack, patternHash])
  @@index([techStack])
  @@index([patternHash])
}

// ── Doctor & Patient Platform (files 7) ─────────────────────────────────────

enum UserRole {
  DOCTOR
  PATIENT
}

enum DoctorStatus {
  ONLINE
  BUSY
  AWAY
  OFFLINE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PostVisibility {
  PUBLIC
  DOCTORS_ONLY
  PRIVATE
}

enum ConsultationStatus {
  REQUESTED
  ACTIVE
  CLOSED
  REJECTED
}

enum RatingStatus {
  PENDING_VALIDATION
  APPROVED
  FLAGGED
  REJECTED
}

model PlatformUser {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  role             UserRole
  name             String
  googleId         String?  @unique
  totpSecret       String?
  twoFactorEnabled Boolean  @default(false)
  createdAt        DateTime @default(now())
  doctor       PlatformDoctor?
  patient      PlatformPatient?
  posts        DiseasePost[]
  replies      DoctorReply[]
  postComments PostComment[]
  postLikes    PostLike[]
  tipsGiven    PlatformTip[]     @relation("TipGiver")
  tipsReceived PlatformTip[]     @relation("TipReceiver")
  consultsAs1  Consultation[]    @relation("ConsultUser1")
  consultsAs2  Consultation[]    @relation("ConsultUser2")
  doctorRatingsGiven DoctorRating[]  @relation("DoctorRatingByPatient")
  doctorRatingsReceived DoctorRating[] @relation("DoctorRatingForDoctor")
  patientRatingsGiven PatientRating[] @relation("PatientRatingByDoctor")
  patientRatingsReceived PatientRating[] @relation("PatientRatingForPatient")
  reviewDecisions RatingValidationRun[] @relation("RatingReviewedBy")

  @@map("PlatformUser")
}

model PlatformDoctor {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty     String
  regNo         String
  hospital      String?
  experience    Int          @default(0)
  verified      Boolean      @default(false)
  degreeFiles   String[]     @default([])
  rating        Float        @default(4.8)
  totalConsults Int          @default(0)
  bio           String?      @db.Text
  fee           Int          @default(500)
  status        DoctorStatus @default(ONLINE)
  createdAt     DateTime     @default(now())
  verifications DoctorVerification[]

  @@map("PlatformDoctor")
}

model PlatformPatient {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  age         Int?
  bloodGroup  String?
  city        String?
  languages   String?
  medications String?      @db.Text
  conditions  String[]     @default([])
  allergies   String[]     @default([])

  @@map("PlatformPatient")
}

model DiseasePost {
  id        String        @id @default(cuid())
  authorId  String
  author    PlatformUser  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String        @db.Text
  tags      String[]      @default([])
  visibility PostVisibility @default(PUBLIC)
  views     Int           @default(0)
  createdAt DateTime      @default(now())
  replies   DoctorReply[]
  comments  PostComment[]
  likes     PostLike[]

  @@index([authorId])
  @@index([createdAt])
}

model PostComment {
  id        String       @id @default(cuid())
  postId    String
  post      DiseasePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    PlatformUser @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String       @db.Text
  createdAt DateTime     @default(now())

  @@index([postId, createdAt])
  @@index([authorId])
}

model PostLike {
  id        String       @id @default(cuid())
  postId    String
  post      DiseasePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model DoctorReply {
  id        String       @id @default(cuid())
  postId    String
  post      DiseasePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    PlatformUser @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  body      String       @db.Text
  createdAt DateTime     @default(now())
  tips      PlatformTip[]

  @@index([postId])
  @@index([doctorId])
}

model PlatformTip {
  id         String       @id @default(cuid())
  giverId    String
  giver      PlatformUser @relation("TipGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   PlatformUser @relation("TipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  replyId    String?
  reply      DoctorReply? @relation(fields: [replyId], references: [id], onDelete: SetNull)
  amount     Int
  note       String?
  createdAt  DateTime     @default(now())

  @@index([receiverId])
}

model Consultation {
  id        String            @id @default(cuid())
  user1Id   String
  user1     PlatformUser      @relation("ConsultUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     PlatformUser      @relation("ConsultUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  ConsultMessage[]
  status    ConsultationStatus @default(REQUESTED)
  requestedById String?
  requestPostId String?
  requestReplyId String?
  patientConsentedRecording Boolean @default(false)
  doctorConsentedRecording Boolean @default(false)
  callRecordings ConsultationCallRecording[]
  doctorRatings DoctorRating[]
  patientRatings PatientRating[]
  startedAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([user1Id, user2Id])
}

model ConsultMessage {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  senderId       String
  body           String       @db.Text
  sentAt         DateTime     @default(now())

  @@index([consultationId])
}

model DoctorVerification {
  id               String             @id @default(cuid())
  doctorId         String
  doctor           PlatformDoctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  provider         String             @default("digilocker")
  digilockerUserId String?
  documentUri      String?
  documentHash     String?
  status           VerificationStatus @default(PENDING)
  rawMeta          Json?
  reviewedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([doctorId, status])
}

model ConsultationCallRecording {
  id                String       @id @default(cuid())
  consultationId    String
  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  provider          String
  recordingUrl      String?
  storageKey        String?
  durationSeconds   Int?
  transcript        String?      @db.Text
  patientConsented  Boolean      @default(false)
  doctorConsented   Boolean      @default(false)
  callStartedAt     DateTime?
  callEndedAt       DateTime?
  meta              Json?
  createdAt         DateTime     @default(now())

  @@index([consultationId, createdAt])
}

model DoctorRating {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         PlatformUser @relation("DoctorRatingForDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  patientId      String
  patient        PlatformUser @relation("DoctorRatingByPatient", fields: [patientId], references: [id], onDelete: Cascade)
  score          Int
  formAnswers    Json
  signature      String?
  status         RatingStatus @default(PENDING_VALIDATION)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  validations    RatingValidationRun[]

  @@unique([consultationId, patientId, doctorId])
  @@index([doctorId, status])
}

model PatientRating {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patientId      String
  patient        PlatformUser @relation("PatientRatingForPatient", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         PlatformUser @relation("PatientRatingByDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  score          Int
  formAnswers    Json
  signature      String?
  status         RatingStatus @default(PENDING_VALIDATION)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  validations    RatingValidationRun[]

  @@unique([consultationId, doctorId, patientId])
  @@index([patientId, status])
}

model RatingValidationRun {
  id               String       @id @default(cuid())
  doctorRatingId   String?
  doctorRating     DoctorRating? @relation(fields: [doctorRatingId], references: [id], onDelete: Cascade)
  patientRatingId  String?
  patientRating    PatientRating? @relation(fields: [patientRatingId], references: [id], onDelete: Cascade)
  confidence       Float
  flags            String[]     @default([])
  evidenceSummary  String?      @db.Text
  autoDecision     RatingStatus @default(PENDING_VALIDATION)
  reviewedById     String?
  reviewedBy       PlatformUser? @relation("RatingReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewerDecision RatingStatus?
  reviewerNote     String?      @db.Text
  createdAt        DateTime     @default(now())
  reviewedAt       DateTime?

  @@index([doctorRatingId])
  @@index([patientRatingId])
}
