generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  createdAt DateTime      @default(now())
  entries   CorpusEntry[]
}

model CorpusEntry {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  meta       Json?
  embedding  Json?
  createdAt  DateTime @default(now())

  @@index([questionId])
}
