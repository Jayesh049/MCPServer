generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestionKind {
  /** Pre-seeded Wikipedia-RAG bank (`qb_*`). */
  BANK
  /** Free-form user question (hash slug `q_*`). */
  DYNAMIC
  /** References manual flows q2–q4 (no Wikipedia corpus). */
  MANUAL_REF
}

enum AnswerSource {
  MANUAL_Q2
  MANUAL_Q3
  MANUAL_Q4
  WEB_RAG
  BANK_RAG
}

model Question {
  id         String       @id @default(cuid())
  slug       String       @unique
  title      String
  promptText String?      @db.Text
  kind       QuestionKind @default(DYNAMIC)
  createdAt  DateTime     @default(now())
  chunks     RagChunk[]
  answers    Answer[]
}

/// Vector-indexed Wikipedia (or fallback) chunks for RAG. DB table legacy name `CorpusEntry`.
model RagChunk {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  meta       Json?
  embedding  Json?
  createdAt  DateTime @default(now())

  @@index([questionId])
  @@map("CorpusEntry")
}

/// Stored responses from manual flows or RAG retrieval (audit / demo).
model Answer {
  id         String        @id @default(cuid())
  questionId String?
  question   Question?     @relation(fields: [questionId], references: [id], onDelete: SetNull)
  source     AnswerSource
  payload    Json
  createdAt  DateTime      @default(now())

  @@index([questionId])
  @@index([source])
}

/// One row per training/indexing batch (e.g. 100-question bank job).
model RagTrainingRun {
  id         String    @id @default(cuid())
  label      String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  metrics    Json?

  @@index([startedAt])
}
