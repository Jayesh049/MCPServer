# --- Cloud hosting (Neon + Render) ---
# Neon (free Postgres): https://neon.tech → create project → copy connection string.
# Paste the same value on Render as env var DATABASE_URL (include ?sslmode=require if offered).
# Example shape (replace user/pass/host/db with yours):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Prisma Postgres / Accelerate or any Postgres URL from your provider.
# Never commit a real URL with password to git — keep secrets only in local `.env`.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Embeddings — auto order: Gemini (if GEMINI_API_KEY) → OpenAI → local Transformers.js
RAG_EMBEDDING_PROVIDER=auto
# GEMINI_API_KEY=          # AI Studio — do not commit; rotate if leaked
# GOOGLE_API_KEY=          # same key, alternate env name accepted by embed.ts
# GEMINI_EMBED_MODEL=gemini-embedding-001   # default; text-embedding-004 often 404 on v1beta now
# GEMINI_GENERATE_MODEL=gemini-1.5-flash
# RAG_GEMINI_SYNTHESIS=1   # after retrieval, call Gemini for a short grounded answer (uses GEMINI_API_KEY)
# Optional paid OpenAI (used when no Gemini key and RAG_EMBEDDING_PROVIDER=auto):
# OPENAI_API_KEY=
# Force one provider: RAG_EMBEDDING_PROVIDER=gemini | openai | local

# RAG_TOP_K=5

# Wikipedia API (free; used by dynamic web RAG — optional overrides)
# WIKIPEDIA_API_ORIGIN=https://en.wikipedia.org
# Hindi articles example:
# WIKIPEDIA_API_ORIGIN=https://hi.wikipedia.org
# WIKIPEDIA_USER_AGENT=YourApp/1.0 (contact@yourdomain)

# --- Patient chat (/api/chat/patient) — Wikipedia RAG first, then LLM ---
# Every question fetches Wikipedia; answers use Groq first, then Gemini if Groq fails.
# GROQ_API_KEY=            # https://console.groq.com/keys — preferred for chat
# GROQ_MODEL=llama-3.1-70b-versatile
# GEMINI_API_KEY=          # fallback LLM — https://aistudio.google.com/apikey
# GEMINI_GENERATE_MODEL=gemini-1.5-flash
# GOOGLE_API_KEY=          # same as GEMINI_API_KEY (alternate env name)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# APP_URL=http://localhost:3001
# PATIENT_CHAT_DISABLE_LLM=1   # force template-only (no LLM call)
# Patient chat: Groq/Gemini direct + store Q&A; Wikipedia only for date/year/live questions
# Optional: npm run train:rag-bank  (for /api/qa bank tools — not required for patient chat)

# MCP-only split: Python RAG agent URL + shared secret (Node MCP calls these for ask_* tools).
# AGENT_RAG_URL=https://your-rag-agent.onrender.com
# AGENT_RAG_SECRET=long-random-string

# --- Imaging ML (10 diseases) — Python sklearn train/predict ---
# IMAGING_ML_PYTHON=python
# After: npm run train:imaging:setup && npm run train:imaging:all

# --- Hugging Face Inference API (Pneumonia ViT + optional TB CXR) ---
# Free token: https://huggingface.co/settings/tokens  (~30k requests/month)
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# HF_PNEUMONIA_MODEL_ID=lxyuan/vit-xray-pneumonia-classification
# HF_PNEUMONIA_MODEL=lxyuan/vit-xray-pneumonia-classification

# Tuberculosis — open-source chest X-ray (optional; uses HF_API_TOKEN above)
# HF_TB_MODEL_ID=fadams/Tuberculosis-Normal-Chest-X-ray
# Train report-text sklearn from TB2.pdf: npm run train:tb2-ml  (requires Python + scikit-learn + pypdf)
# TB_ML_PYTHON=python

# Flask disease corpus ML sidecar (optional). See ml/flask_disease/README.md
# DISEASE_ML_URL=http://localhost:5001
# DISEASE_ML_SECRET=long-random-string

# Backend HTTP port (Next.js proxies /api → this). MCP tester: http://127.0.0.1:3333/tester
# PORT=3333
# MCP_HTTP_PORT=3333
# DISEASE_ML_STORAGE=local
# DISEASE_ML_STORAGE_ROOT=./ml/artifacts/disease_ml
# Production on ephemeral disk: DISEASE_ML_STORAGE=s3 plus DISEASE_ML_S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# --- Dev self-healing (CLI: npm run dev:heal | HTTP: POST /api/healer/plan | /api/healer/fix) ---
# Uses same LLM keys as patient chat (ANTHROPIC > GROQ > GEMINI > OPENAI).
# HEALER_AUTO_APPLY=1
# HEALER_COMMAND=npm run dev
# HEALER_DEBOUNCE_MS=2000
# HEALER_MAX_RETRIES_PER_PATTERN=3
# HEALER_FORCE_RESTART=auto
# HEALER_ALLOW_PREFIXES=src,frontend,ml
# HEALER_GEMINI_MODEL=gemini-1.5-flash
# HEALER_OPENAI_MODEL=gpt-4o-mini
