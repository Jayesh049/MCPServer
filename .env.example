# Default local: SQLite file (zero Docker). For Postgres use docker-compose + URL below.
DATABASE_URL=file:./prisma/rag.sqlite
# DATABASE_URL=postgresql://mcpuser:mcppass@127.0.0.1:5434/mcprag

# Embeddings — FREE by default (Transformers.js local model, first run may download ~MB to cache)
# auto = use OpenAI only if OPENAI_API_KEY is set; otherwise local embeddings
RAG_EMBEDDING_PROVIDER=auto
# Force free local model (default when no OpenAI key):
# RAG_EMBEDDING_PROVIDER=local
# RAG_LOCAL_EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# Optional: paid OpenAI embeddings (only used when key is set + provider auto/openai)
# OPENAI_API_KEY="sk-..."
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_MODEL=text-embedding-3-small

# Optional RAG tuning
# RAG_TOP_K=5

# MCP HTTP (Prompt Opinion / ngrok)
# MCP_TRANSPORT=http
# PORT=3333
