# Prisma Postgres (pooled connection string from Prisma Console / Accelerate).
# Format is typically:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Embeddings (free default)
RAG_EMBEDDING_PROVIDER=local
# Optional paid OpenAI:
# OPENAI_API_KEY=
# RAG_EMBEDDING_PROVIDER=auto

# RAG_TOP_K=5
# MCP_TRANSPORT=http
# PORT=3333
